<Window x:Class="POE___CyberBot._01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE___CyberBot._01"
        mc:Ignorable="d"
        Title="CYBERBOT ROBBO 29T" Height="550" Width="900">
    <Grid>
        <Grid Margin="10" Background="black">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Log -->

            <ListBox x:Name="lstChatLog" Grid.Row="1" Margin="0,10" Background="LightGray"
         Foreground="Black" FontSize="20" Padding="10" BorderBrush="Gray" BorderThickness="1">
            </ListBox>


            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10" VerticalAlignment="Center">

                <TextBox x:Name="txtUserInput" Width="600" Height="35" Margin="10,0,8,0"
             Background="LightGray" FontSize="14" Padding="5" />

                <Button Content="Send" Width="80" Height="35" Background="#007ACC" Foreground="White"
                FontWeight="Bold" Click="btnSend_Click" Margin="0,0,8,0"/>
                <Button Content="Start Quiz" Width="75" Height="35" Background="#008000" Foreground="White"
                FontWeight="Bold" Click="btnStartQuiz_Click" />    
                <!-- Add extra margin on Exit button's right so Start Quiz is visually separated -->

                <Button Content="Exit" Width="80" Height="35" Background="#CC0000" Foreground="White"
                FontWeight="Bold" Margin="8,0,0,0" Click="btnExit_Click" />
            </StackPanel>


        </Grid>

    </Grid>
</Window>
