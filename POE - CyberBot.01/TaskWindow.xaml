<Window x:Class="POE___CyberBot._01.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Assistant" Height="450" Width="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Task Input -->
        <StackPanel Orientation="Vertical" Margin="0,0,0,10">
            <TextBox x:Name="txtTitle" Margin="0,5" Text="Task Title" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" />
            <TextBox x:Name="txtDescription" Margin="0,5" Text="Task Description" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" />
            <DatePicker x:Name="dateReminder" Margin="0,5" />
            <Button Content="Add Task" Click="AddTask_Click" />
        </StackPanel>

        <!-- Task List -->
        <ListBox x:Name="lstTasks" Grid.Row="1" Margin="0,10"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Mark Completed" Click="MarkCompleted_Click" Margin="5"/>
            <Button Content="Delete Task" Click="DeleteTask_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
